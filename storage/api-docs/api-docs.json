        "/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Yangi foydalanuvchini ro'yxatdan o'tkazish",
                "description": "register() — POST /register",
                "operationId": "858ecba1c675ee39e49f2b0c265443ff",
                "parameters": [
